# MongoDB 连接字符串
# 本地开发：mongodb://localhost:27017/personal_tech_site
# Docker 容器间：mongodb://mongo:27017/personal_tech_site（mongo 是容器服务名）
# 带认证：mongodb://用户名:密码@host:port/数据库名?authSource=admin
MONGODB_URI=mongodb://localhost:27017/personal_tech_site

# CORS 允许的来源（生产环境改成你的域名，如 https://example.com）
CORS_ORIGIN=*

# 后端服务端口
PORT=3001

# Node 环境
NODE_ENV=development
